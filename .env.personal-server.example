# CharityPilot personal-server example configuration.
#
# Reference contract only. The supported installer creates .env.personal-server
# exclusively and refuses to overwrite it:
#
#   npm run personal:server:init -- --help
#
# Do not copy/edit this example as the normal installation workflow and never
# commit the generated real file. If manually inspecting values for recovery,
# keep POSTGRES_PASSWORD URL-safe because Compose uses it in DATABASE_URL;
#    a 64-character hexadecimal value is suitable.
# CHARITYPILOT_PERSONAL_SERVER_ORIGIN must be the exact address users open,
#    with no trailing slash. For private-tunnel access, use its HTTPS origin.

CHARITYPILOT_PERSONAL_SERVER_PORT=8080
CHARITYPILOT_PERSONAL_SERVER_ORIGIN=http://localhost:8080

POSTGRES_DB=charitypilot_personal_server
POSTGRES_USER=charitypilot_personal_server
POSTGRES_PASSWORD=CHANGE_ME_USE_64_HEXADECIMAL_CHARACTERS

JWT_SECRET=CHANGE_ME_JWT_USE_AT_LEAST_32_RANDOM_CHARACTERS
# Independent root secret for recovery token/rate-key derivation. Use the
# canonical even-length hex or unpadded base64url encoding of 32-64 random bytes.
# Do not reuse JWT_SECRET or READINESS_API_KEY.
AUTH_RECOVERY_SECRET=CHANGE_ME_CANONICAL_32_TO_64_RANDOM_BYTES_HEX_OR_BASE64URL
JWT_EXPIRY=15m
REFRESH_TOKEN_TTL_DAYS=7
READINESS_API_KEY=CHANGE_ME_READINESS_USE_AT_LEAST_32_RANDOM_CHARACTERS

# Used only by the explicit, profile-gated personal-init service. The compiled
# initializer refuses to overwrite an existing personal-server workspace.
PERSONAL_SERVER_OWNER_EMAIL=owner@example.invalid
PERSONAL_SERVER_OWNER_NAME=CharityPilot Owner
PERSONAL_SERVER_ORGANISATION_NAME=My Charity
# Intentionally blank: do not persist the bootstrap password in this file.
# The one-shot host initializer must inject it only for the init process.
PERSONAL_SERVER_OWNER_PASSWORD=

# Stripe, Resend, Supabase, public DNS/TLS, alert webhooks, and background jobs
# are intentionally absent from this personal-server profile.
