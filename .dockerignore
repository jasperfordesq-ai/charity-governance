# Positive allow-list for every CharityPilot Docker build context. Docker sends
# only application source and the exact build helpers below; arbitrary repo files,
# documents, evidence, backups, VCS/agent state and local secrets never enter the
# context, even when untracked.
**

!package.json
!package-lock.json
!tsconfig.base.json
!turbo.json

!apps/
!apps/api/
!apps/api/**
!apps/web/
!apps/web/**

!packages/
!packages/shared/
!packages/shared/**

!scripts/
!scripts/next-build-fs-retry.cjs
!scripts/clean-next-export.cjs

!e2e/
!e2e/docker/
!e2e/docker/Dockerfile
!e2e/docker/init-disposable-database.sql
!e2e/docker/tcp-gateway.mjs

# Explicit deny rules remain after the allow-list so a private file can never be
# re-included by a broad application-directory rule.
.git
**/.git
.env
.env.*
**/.env
**/.env.*
node_modules
**/node_modules
.turbo
**/.turbo
.next
**/.next
.next-build*
**/.next-build*
next-codex-build
**/next-codex-build
.test-dist
**/.test-dist
dist
**/dist
*.tsbuildinfo
**/*.tsbuildinfo
coverage
**/coverage
out
**/out
test-results
**/test-results
playwright-report
**/playwright-report
.nyc_output
**/.nyc_output
.charitypilot-backups
.charitypilot-backups/
**/.charitypilot-backups/
.charitypilot-launch-evidence/
**/.charitypilot-launch-evidence/
.charitypilot-local-storage/
**/.charitypilot-local-storage/
.charitypilot-readiness-test-storage/
**/.charitypilot-readiness-test-storage/
.agents/
**/.agents/
.claude/
**/.claude/
.codex
.codex/
**/.codex
**/.codex/
.codex-*
**/.codex-*
production-launch-evidence*.json
**/production-launch-evidence*.json
*.dump
**/*.dump
npm-debug.log*
