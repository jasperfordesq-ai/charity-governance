{
  "name": "charitypilot",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test && npm run test:production-check && npm run test:local-docker",
    "test:production-check": "node --test scripts/check-production.test.mjs scripts/postgres-backup.test.mjs scripts/security-scan.test.mjs scripts/production-deploy-preflight.test.mjs scripts/production-compose-deploy.test.mjs scripts/production-compose-rollback.test.mjs scripts/production-launch-evidence.test.mjs scripts/production-release-run-evidence.test.mjs scripts/check-production-supabase.test.mjs scripts/check-production-providers.test.mjs scripts/check-production-hosting.test.mjs scripts/check-production-observability.test.mjs scripts/check-production-database.test.mjs scripts/smoke-production-deploy.test.mjs scripts/start-ci-postgres.test.mjs scripts/generate-production-env.test.mjs scripts/launch-status.test.mjs",
    "test:local-docker": "node --test scripts/check-local-docker.test.mjs",
    "test:local-docker:smoke": "node scripts/smoke-local-docker.mjs",
    "lint": "turbo lint",
    "security:secrets": "node scripts/security-scan.mjs secrets",
    "security:sast": "node scripts/security-scan.mjs sast",
    "security:scan": "npm run security:secrets && npm run security:sast",
    "audit:platform": "node scripts/platform-completion-audit.mjs",
    "setup:production-env": "node scripts/generate-production-env.mjs",
    "launch:status": "node scripts/launch-status.mjs",
    "check:production": "node scripts/check-production.mjs",
    "check:production:evidence": "node scripts/production-launch-evidence.mjs",
    "check:production:release-run": "node scripts/production-release-run-evidence.mjs",
    "check:production:supabase": "node scripts/check-production-supabase.mjs",
    "check:production:providers": "node scripts/check-production-providers.mjs",
    "check:production:hosting": "node scripts/check-production-hosting.mjs",
    "check:production:observability": "node scripts/check-production-observability.mjs",
    "check:production:database": "node scripts/check-production-database.mjs",
    "check:production:evidence:template": "node scripts/generate-production-launch-evidence-template.mjs",
    "deploy:preflight": "node scripts/production-deploy-preflight.mjs",
    "deploy:production": "node scripts/production-compose-deploy.mjs",
    "deploy:rollback": "node scripts/production-compose-rollback.mjs",
    "clean": "turbo clean",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:migrate:local-docker": "node scripts/migrate-local-docker.mjs",
    "db:seed": "turbo db:seed",
    "db:backup": "node scripts/postgres-backup.mjs backup",
    "db:restore:verify": "node scripts/postgres-backup.mjs verify-restore",
    "test:e2e": "cd e2e && npm test",
    "test:e2e:install": "cd e2e && npm install && npm run install:browsers",
    "reliability:report": "node scripts/reliability-report.mjs",
    "reliability:ledger": "node scripts/reliability-report.mjs --write",
    "release:ready": "node scripts/release-ready.mjs"
  },
  "devDependencies": {
    "turbo": "^2.9.16",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@11.11.0",
  "overrides": {
    "fast-uri": "3.1.2",
    "form-data": "4.0.6",
    "postcss": "8.5.14",
    "qs": "6.15.2",
    "ws": "8.21.0"
  }
}
