{
  "name": "charitypilot",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test && npm run test:production-check && npm run test:local-docker",
    "test:production-check": "node --test scripts/check-production.test.mjs scripts/postgres-backup.test.mjs scripts/security-scan.test.mjs scripts/production-deploy-preflight.test.mjs scripts/start-ci-postgres.test.mjs",
    "test:local-docker": "node --test scripts/check-local-docker.test.mjs",
    "test:local-docker:smoke": "node scripts/smoke-local-docker.mjs",
    "lint": "turbo lint",
    "security:secrets": "node scripts/security-scan.mjs secrets",
    "security:sast": "node scripts/security-scan.mjs sast",
    "security:scan": "npm run security:secrets && npm run security:sast",
    "check:production": "node scripts/check-production.mjs",
    "deploy:preflight": "node scripts/production-deploy-preflight.mjs",
    "clean": "turbo clean",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "db:backup": "node scripts/postgres-backup.mjs backup",
    "db:restore:verify": "node scripts/postgres-backup.mjs verify-restore"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@11.11.0",
  "overrides": {
    "fast-uri": "3.1.2",
    "postcss": "8.5.14",
    "qs": "6.15.2",
    "ws": "8.21.0"
  }
}
