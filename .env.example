# =============================================================================
# CharityPilot — Environment Variables
# Copy to .env and fill in real values.
# Port assignments (avoids conflicts with other Nexus projects):
#   API → 3002  |  Web → 3003  |  PostgreSQL → 5434
# =============================================================================

# Database
DATABASE_URL=postgresql://charitypilot:charitypilot_dev@localhost:5434/charitypilot

# Server
PORT=3002
HOST=0.0.0.0

# JWT
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-string-at-least-32-chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Frontend URL (for CORS, email links)
FRONTEND_URL=http://localhost:3003
API_URL=http://localhost:3002

# Stripe
# Production hardening: checkout is disabled unless all Stripe values below are real.
# Create separate monthly/yearly prices for Essentials and Complete in Stripe.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_ESSENTIALS_MONTHLY_PRICE_ID=price_...
STRIPE_ESSENTIALS_YEARLY_PRICE_ID=price_...
STRIPE_COMPLETE_MONTHLY_PRICE_ID=price_...
STRIPE_COMPLETE_YEARLY_PRICE_ID=price_...

# Resend (email)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@charitypilot.ie

# File storage (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=documents

# Next.js public vars
NEXT_PUBLIC_API_URL=http://localhost:3002
