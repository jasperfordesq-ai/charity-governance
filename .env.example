# =============================================================================
# CharityPilot — Environment Variables
# Copy to .env and fill in real values.
# Port assignments (avoids conflicts with other Nexus projects):
#   API → 3002  |  Web → 3003  |  PostgreSQL → 5434
# =============================================================================

# Database
DATABASE_URL=postgresql://charitypilot:charitypilot_dev@localhost:5434/charitypilot

# Server
PORT=3002
HOST=0.0.0.0
TRUSTED_PROXY_ADDRESSES=
READINESS_API_KEY=change-me-local-readiness-key-at-least-32-characters

# JWT
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
# Deterministic local-only root key. Generate an independent canonical 32-64 byte
# hex/base64url value for every non-local environment; never reuse JWT_SECRET.
AUTH_RECOVERY_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
JWT_EXPIRY=15m
REFRESH_TOKEN_TTL_DAYS=7

# Frontend URL (for CORS, email links)
FRONTEND_URL=http://localhost:3003
API_URL=http://localhost:3002

# Stripe
# Production hardening: checkout is disabled unless all Stripe values below are real.
# Create separate monthly/yearly prices for Essentials and Complete in Stripe.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_ESSENTIALS_MONTHLY_PRICE_ID=price_...
STRIPE_ESSENTIALS_YEARLY_PRICE_ID=price_...
STRIPE_COMPLETE_MONTHLY_PRICE_ID=price_...
STRIPE_COMPLETE_YEARLY_PRICE_ID=price_...
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=bpc_...

# Resend (email)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@charitypilot.ie

# File storage (Supabase)
# Use local filesystem storage for laptop-only testing.
DOCUMENT_STORAGE_DRIVER=local
LOCAL_FILE_STORAGE_DIR=.charitypilot-local-storage/documents
STORAGE_DOWNLOAD_TIMEOUT_MS=10000

# Later production/provider testing can switch DOCUMENT_STORAGE_DRIVER back to Supabase by
# filling these provider values and setting DOCUMENT_STORAGE_DRIVER=supabase or leaving it unset.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=documents

# Next.js public vars
NEXT_PUBLIC_API_URL=http://localhost:3002

# Optional local demo seed. Leave disabled in production.
SEED_LOCAL_ADMIN=true
LOCAL_ADMIN_EMAIL=admin@charitypilot.local
LOCAL_ADMIN_PASSWORD=LocalAdmin123!
LOCAL_ADMIN_NAME=Local CharityPilot Admin
LOCAL_ADMIN_ORGANISATION=My Local Charity

# Legacy demo seed support. Leave disabled unless you specifically need the old demo account.
SEED_DEMO_WORKSPACE=false
DEMO_PASSWORD=
