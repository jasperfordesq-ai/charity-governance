{
	admin off
	auto_https off
	persist_config off
}

:8080 {
	encode zstd gzip
	header {
		-Server
		X-CharityPilot-Deployment "personal-server"
		X-Robots-Tag "noindex, nofollow, noarchive"
	}

	@charitypilot_api path /api/v1/*
	handle @charitypilot_api {
		reverse_proxy api:3002
	}

	handle {
		reverse_proxy web:3003
	}

	log {
		output stdout
		format json
	}
}
