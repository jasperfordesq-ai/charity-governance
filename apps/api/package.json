{
  "name": "@charitypilot/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "build": "tsc",
    "test": "tsc -p tsconfig.json && node --test dist/tests/*.test.js",
    "start": "node dist/start.js",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "jobs:production-scheduler": "node dist/jobs/production-scheduler.js",
    "jobs:deadline-reminders": "node dist/jobs/send-deadline-reminders.js",
    "jobs:reconcile-deadline-reminder": "node dist/jobs/reconcile-deadline-reminder.js",
    "jobs:document-storage-cleanup": "node dist/jobs/cleanup-document-storage.js",
    "jobs:recover-team-ownership": "node dist/jobs/recover-team-ownership.js",
    "jobs:reconcile-billing-authority": "node dist/jobs/reconcile-billing-authority.js"
  },
  "dependencies": {
    "@charitypilot/shared": "*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@prisma/client": "6.19.3",
    "@supabase/supabase-js": "^2.49.0",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "resend": "^4.5.0",
    "stripe": "^17.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.0",
    "pino-pretty": "^13.0.0",
    "prisma": "6.19.3",
    "tsx": "^4.23.0",
    "typescript": "^5.8.0"
  }
}
