generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganisationComplexity {
  SIMPLE
  COMPLEX
}

enum LegalForm {
  CLG
  TRUST
  UNINCORPORATED_ASSOCIATION
  OTHER
}

enum CharitablePurpose {
  POVERTY_RELIEF
  EDUCATION
  RELIGION
  COMMUNITY_BENEFIT
}

enum ComplianceStatus {
  COMPLIANT
  WORKING_TOWARDS
  NOT_STARTED
  NOT_APPLICABLE
  EXPLAIN
}

enum ComplianceSignoffStatus {
  DRAFT
  BOARD_REVIEW
  APPROVED
}

enum ComplianceAuditEventType {
  RECORD_BASELINE_IMPORTED
  RECORD_CREATED
  RECORD_UPDATED
  SIGNOFF_BASELINE_IMPORTED
  SIGNOFF_UPDATED
  APPROVAL_GRANTED
  APPROVAL_INVALIDATED
  LEGACY_APPROVAL_INVALIDATED
}

enum ComplianceApprovalInvalidationReason {
  RECORD_CHANGED
  MANUAL_STATUS_CHANGE
  LEGACY_APPROVAL_UNBOUND
}

enum SubscriptionPlan {
  ESSENTIALS
  COMPLETE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum BillingCheckoutAttemptStatus {
  PENDING
  SESSION_CREATED
  COMPLETED
}

enum BillingAuthorityGrantKind {
  CHECKOUT
  PORTAL
}

enum BillingAuthorityGrantState {
  CLAIMED
  PROVIDER_STARTED
  CAPABILITY_ISSUED
  RELEASED
}

enum BillingAuthorityGrantReleaseReason {
  PROVIDER_CONFIRMED_NOT_ISSUED
  PROVIDER_CAPABILITY_REVOKED
  PROVIDER_CAPABILITY_TERMINAL
  CHECKOUT_SAFE_RELEASE_AFTER_ELAPSED
  RESTRICTED_OPERATOR_ATTESTATION
}

enum DocumentCategory {
  CONSTITUTION
  POLICY
  BOARD_MINUTES
  FINANCIAL_STATEMENT
  INSURANCE
  ANNUAL_REPORT
  RISK_REGISTER
  CODE_OF_CONDUCT
  STRATEGIC_PLAN
  OTHER
}

enum RegisterStatus {
  OPEN
  MONITORING
  CLOSED
}

enum ConflictStatus {
  DECLARED
  MANAGED
  CLOSED
}

enum RiskCategory {
  GOVERNANCE
  FINANCIAL
  OPERATIONAL
  LEGAL
  SAFEGUARDING
  REPUTATIONAL
  FUNDRAISING
  DATA_PROTECTION
  OTHER
}

enum AnnualReportFilingStatus {
  NOT_STARTED
  IN_PROGRESS
  BOARD_APPROVED
  FILED
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum OrganisationLifecycleStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum UserLifecycleStatus {
  ACTIVE
  SUSPENDED
  REMOVED
}

enum AuthSessionRevocationReason {
  LOGOUT
  ROTATED
  REFRESH_REUSE
  PASSWORD_RESET
  MEMBER_SUSPENDED
  MEMBER_REMOVED
  ADMIN_SESSION_REVOKED
  ADMIN_ALL_SESSIONS_REVOKED
  USER_SESSION_REVOKED
  USER_ALL_SESSIONS_REVOKED
  OWNERSHIP_CHANGED
  ORGANISATION_INACTIVE
  LEGACY_UNSPECIFIED
}

enum SecurityAuditActorKind {
  USER
  SUPPORT
  SYSTEM
}

enum SecurityAuditEventType {
  MEMBER_SUSPENDED
  MEMBER_REACTIVATED
  MEMBER_REMOVED
  MEMBER_ROLE_CHANGED
  OWNERSHIP_TRANSFERRED
  OWNERSHIP_RECOVERED
  SESSION_REVOKED
  ALL_SESSIONS_REVOKED
  ORGANISATION_SUSPENDED
  ORGANISATION_REACTIVATED
  ORGANISATION_CLOSED
  INVITE_REVOKED
}

enum DeadlineReminderStatus {
  RESERVED
  SENDING
  SENT
  SKIPPED
  FAILED
  UNCERTAIN
}

enum DeadlineReminderReconciliationOutcome {
  ACCEPTED_CONFIRMED
  NOT_ACCEPTED_CONFIRMED
  UNKNOWN_ACKNOWLEDGED
}

enum GeneratedDeadlineKind {
  CHARITY_ANNUAL_REPORT
  COMPANY_FINANCIAL_STATEMENTS
  COMPANY_ANNUAL_MEMBER_ACTION
  CRO_ANNUAL_RETURN
  LEGACY_UNVERIFIED
}

enum DeadlineSupersessionReason {
  INPUT_CHANGED
  INPUT_REMOVED
  RULE_CHANGED
  RECURRENCE_ADVANCED
  LEGACY_MIGRATION
}

model Organisation {
  id                                      String                      @id @default(cuid())
  name                                    String
  rcnNumber                               String?
  croNumber                               String?
  legalForm                               LegalForm?
  legalFormConfirmedAt                    DateTime?
  complexity                              OrganisationComplexity      @default(SIMPLE)
  charitablePurpose                       CharitablePurpose[]
  financialYearEnd                        DateTime?                   @db.Date
  registeredAddress                       String?
  contactEmail                            String?
  contactPhone                            String?
  website                                 String?
  dateRegistered                          DateTime?                   @db.Date
  incorporationDate                       DateTime?                   @db.Date
  croAnnualReturnDate                     DateTime?                   @db.Date
  croAnnualReturnDateConfirmedAt          DateTime?
  lastActualAgmDate                       DateTime?                   @db.Date
  lastUnanimousAnnualMemberResolutionDate DateTime?                   @db.Date
  memberCount                             Int?
  conditionalObligationProfile            Json?
  lifecycleStatus                         OrganisationLifecycleStatus @default(ACTIVE)
  lifecycleChangedAt                      DateTime                    @default(now())
  lifecycleVersion                        Int                         @default(1)

  stripeCustomerId String? @unique

  users                       User[]
  boardMembers                BoardMember[]
  complianceRecords           ComplianceRecord[]
  complianceSignoffs          ComplianceSignoff[]
  complianceApprovalSnapshots ComplianceApprovalSnapshot[]
  documents                   Document[]
  deadlines                   Deadline[]
  conflictRecords             ConflictRecord[]
  riskRecords                 RiskRecord[]
  complaintRecords            ComplaintRecord[]
  fundraisingRecords          FundraisingRecord[]
  annualReportReadiness       AnnualReportReadiness[]
  financialControlReviews     FinancialControlReview[]
  teamInvites                 TeamInvite[]
  deadlineReminderLogs        DeadlineReminderLog[]
  subscription                Subscription?
  billingCheckoutAttempt      BillingCheckoutAttempt?
  billingAuthorityGrants      BillingAuthorityGrant[]
  securityAuditEvents         SecurityAuditEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  name                String
  passwordHash        String
  role                UserRole            @default(MEMBER)
  organisationId      String
  organisation        Organisation        @relation(fields: [organisationId], references: [id])
  emailVerified       Boolean             @default(false)
  lifecycleStatus     UserLifecycleStatus @default(ACTIVE)
  membershipChangedAt DateTime            @default(now())
  membershipVersion   Int                 @default(1)

  resetToken        String?   @unique
  resetTokenExpiry  DateTime?
  verifyToken       String?   @unique
  verifyTokenExpiry DateTime?

  complianceUpdates            ComplianceRecord[]    @relation("UpdatedBy")
  signoffUpdates               ComplianceSignoff[]   @relation("SignoffUpdatedBy")
  documentUploads              Document[]            @relation("UploadedBy")
  sentInvites                  TeamInvite[]          @relation("InvitedBy")
  reminderLogs                 DeadlineReminderLog[]
  authSessions                 AuthSession[]
  billingAuthorityGrants       BillingAuthorityGrant[] @relation("BillingAuthorityActor")
  securityAuditEventsAsActor   SecurityAuditEvent[]  @relation("SecurityAuditActor")
  securityAuditEventsAsSubject SecurityAuditEvent[]  @relation("SecurityAuditSubject")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organisationId])
  @@index([organisationId])
  @@index([organisationId, lifecycleStatus, role, id])
}

model AuthSession {
  id               String                       @id @default(cuid())
  userId           String
  user             User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingAuthorityGrants BillingAuthorityGrant[] @relation("BillingAuthoritySession")
  refreshTokenHash String                       @unique
  familyId         String                       @default(uuid()) @db.Uuid
  familyCreatedAt  DateTime                     @default(now())
  deviceLabel      String?
  expiresAt        DateTime
  revokedAt        DateTime?
  revocationReason AuthSessionRevocationReason?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@unique([id, userId])
  @@index([userId, revokedAt, expiresAt, id])
  @@index([userId, familyCreatedAt, familyId])
  @@index([expiresAt])
}

model BillingAuthorityGrant {
  id                     String                             @id @default(uuid()) @db.Uuid
  organisationId         String
  organisation           Organisation                       @relation(fields: [organisationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  kind                   BillingAuthorityGrantKind
  actorUserId            String
  actorUser              User                               @relation("BillingAuthorityActor", fields: [actorUserId, organisationId], references: [id, organisationId], onDelete: Restrict, onUpdate: Restrict)
  actorSessionId         String
  actorSession           AuthSession                        @relation("BillingAuthoritySession", fields: [actorSessionId, actorUserId], references: [id, userId], onDelete: Restrict, onUpdate: Restrict)
  actorMembershipVersion Int
  state                  BillingAuthorityGrantState         @default(CLAIMED)
  providerResourceId     String?                            @unique
  safeReleaseAfter       DateTime?
  claimedAt              DateTime                           @default(now())
  providerStartedAt      DateTime?
  capabilityIssuedAt     DateTime?
  releasedAt             DateTime?
  releaseReason          BillingAuthorityGrantReleaseReason?
  releaseActor           String?
  releaseEvidence        Json?
  createdAt              DateTime                           @default(now())
  updatedAt              DateTime                           @default(now()) @updatedAt

  @@index([organisationId, state, id])
  @@index([actorUserId, state, id])
  @@index([actorSessionId, state, id])
  @@index([safeReleaseAfter, state, id])
}

model SecurityAuditEvent {
  id               String                 @id @default(cuid())
  organisationId   String
  organisation     Organisation           @relation(fields: [organisationId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  type             SecurityAuditEventType
  actorKind        SecurityAuditActorKind
  actorUserId      String?
  actorUser        User?                  @relation("SecurityAuditActor", fields: [actorUserId, organisationId], references: [id, organisationId], onDelete: Restrict, onUpdate: Restrict)
  actorLabel       String
  subjectLabel     String
  subjectUserId    String?
  subjectUser      User?                  @relation("SecurityAuditSubject", fields: [subjectUserId, organisationId], references: [id, organisationId], onDelete: Restrict, onUpdate: Restrict)
  subjectSessionId String?
  reason           String
  context          Json?
  requestId        String?
  eventVersion     Int                    @default(1)
  occurredAt       DateTime               @default(now())

  @@index([organisationId, occurredAt, id])
  @@index([organisationId, subjectUserId, occurredAt, id])
  @@index([organisationId, actorUserId, occurredAt, id])
}

model GovernancePrinciple {
  id          String @id @default(cuid())
  number      Int    @unique
  title       String
  description String
  sortOrder   Int

  standards GovernanceStandard[]
}

model GovernanceStandard {
  id           String              @id @default(cuid())
  principleId  String
  principle    GovernancePrinciple @relation(fields: [principleId], references: [id])
  code         String              @unique
  title        String
  isCore       Boolean
  isAdditional Boolean
  sortOrder    Int

  complianceRecords ComplianceRecord[]
  documentLinks     DocumentStandardLink[]

  @@index([principleId])
}

model ComplianceRecord {
  id             String             @id @default(cuid())
  organisationId String
  organisation   Organisation       @relation(fields: [organisationId], references: [id])
  standardId     String
  standard       GovernanceStandard @relation(fields: [standardId], references: [id])
  reportingYear  Int

  status          ComplianceStatus @default(NOT_STARTED)
  actionTaken     String?
  evidence        String?
  notes           String?
  explanationIfNA String?
  revision        Int              @default(1)

  updatedById String?
  updatedBy   User?   @relation("UpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organisationId, standardId, reportingYear])
  @@index([organisationId, reportingYear])
}

model ComplianceSignoff {
  id               String                  @id @default(cuid())
  organisationId   String
  organisation     Organisation            @relation(fields: [organisationId], references: [id])
  reportingYear    Int
  status           ComplianceSignoffStatus @default(DRAFT)
  boardMeetingDate DateTime?
  minuteReference  String?
  approvedByName   String?
  approvedByRole   String?
  approvalNotes    String?
  approvedAt       DateTime?
  revision         Int                     @default(1)
  approvalSequence Int                     @default(0)

  currentApprovalSnapshotId String?                     @unique
  currentApprovalSnapshot   ComplianceApprovalSnapshot? @relation("CurrentComplianceApproval", fields: [currentApprovalSnapshotId], references: [id], onDelete: Restrict)

  invalidatedAt      DateTime?
  invalidationReason ComplianceApprovalInvalidationReason?
  invalidatedById    String?

  updatedById String?
  updatedBy   User?   @relation("SignoffUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organisationId, reportingYear])
  @@index([organisationId, reportingYear])
}

model ComplianceApprovalSnapshot {
  id               String       @id @default(cuid())
  organisationId   String
  organisation     Organisation @relation(fields: [organisationId], references: [id], onDelete: Restrict)
  reportingYear    Int
  approvalSequence Int
  formatVersion    Int          @default(1)

  evidenceHash String @db.Char(64)
  snapshotHash String @db.Char(64)
  payload      Json

  approvedAt    DateTime
  createdById   String
  createdByName String?
  createdAt     DateTime @default(now())

  currentForSignoff ComplianceSignoff? @relation("CurrentComplianceApproval")

  @@unique([organisationId, reportingYear, approvalSequence])
  @@unique([id, organisationId, reportingYear, approvalSequence])
  @@index([organisationId, reportingYear, approvedAt])
}

model ComplianceAuditEvent {
  id             String                   @id @default(cuid())
  organisationId String
  reportingYear  Int
  type           ComplianceAuditEventType

  standardId         String?
  complianceRecordId String?
  signoffId          String?
  approvalSnapshotId String?

  actorUserId String?
  actorName   String?

  fromRevision Int?
  toRevision   Int?
  reason       ComplianceApprovalInvalidationReason?
  beforeState  Json?
  afterState   Json?
  occurredAt   DateTime                              @default(now())

  @@unique([complianceRecordId, toRevision])
  @@unique([signoffId, toRevision])
  @@index([organisationId, reportingYear, occurredAt])
  @@index([complianceRecordId, occurredAt])
}

model BoardMember {
  id                 String           @id @default(cuid())
  organisationId     String
  organisation       Organisation     @relation(fields: [organisationId], references: [id])
  name               String
  role               String
  email              String?
  appointedDate      DateTime
  termEndDate        DateTime?
  isActive           Boolean          @default(true)
  conductSigned      Boolean          @default(false)
  conductSignedDate  DateTime?
  inductionCompleted Boolean          @default(false)
  inductionDate      DateTime?
  conflictRecords    ConflictRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
}

model Document {
  id                   String           @id @default(cuid())
  organisationId       String
  organisation         Organisation     @relation(fields: [organisationId], references: [id])
  name                 String
  description          String?
  category             DocumentCategory
  fileUrl              String
  fileSize             Int
  mimeType             String
  version              Int              @default(1)
  owner                String?
  approvedDate         DateTime?
  nextReviewDate       DateTime?
  boardMinuteReference String?

  uploadedById String?
  uploadedBy   User?   @relation("UploadedBy", fields: [uploadedById], references: [id])

  standardLinks DocumentStandardLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
}

model DocumentStandardLink {
  id         String             @id @default(cuid())
  documentId String
  document   Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  standardId String
  standard   GovernanceStandard @relation(fields: [standardId], references: [id])

  @@unique([documentId, standardId])
}

model DocumentStorageDeletion {
  id             String    @id @default(cuid())
  organisationId String
  storagePath    String
  attempts       Int       @default(0)
  lastError      String?
  claimedAt      DateTime?
  processedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organisationId])
  @@index([processedAt, createdAt])
  @@index([processedAt, claimedAt, createdAt])
}

model ConflictRecord {
  id              String         @id @default(cuid())
  organisationId  String
  organisation    Organisation   @relation(fields: [organisationId], references: [id])
  boardMemberId   String?
  boardMember     BoardMember?   @relation(fields: [boardMemberId], references: [id], onDelete: SetNull)
  trusteeName     String
  matter          String
  nature          String
  dateDeclared    DateTime
  meetingDate     DateTime?
  actionTaken     String
  decision        String?
  status          ConflictStatus @default(DECLARED)
  minuteReference String?
  nextReviewDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
  @@index([boardMemberId])
}

model RiskRecord {
  id                   String         @id @default(cuid())
  organisationId       String
  organisation         Organisation   @relation(fields: [organisationId], references: [id])
  title                String
  category             RiskCategory
  description          String
  likelihood           Int
  impact               Int
  mitigation           String
  owner                String?
  reviewDate           DateTime?
  status               RegisterStatus @default(OPEN)
  boardMinuteReference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
}

model ComplaintRecord {
  id                   String         @id @default(cuid())
  organisationId       String
  organisation         Organisation   @relation(fields: [organisationId], references: [id])
  receivedDate         DateTime
  source               String?
  summary              String
  actionTaken          String?
  outcome              String?
  status               RegisterStatus @default(OPEN)
  reviewedByBoard      Boolean        @default(false)
  boardMinuteReference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
}

model FundraisingRecord {
  id                   String         @id @default(cuid())
  organisationId       String
  organisation         Organisation   @relation(fields: [organisationId], references: [id])
  name                 String
  activityType         String
  startDate            DateTime?
  endDate              DateTime?
  publicFacing         Boolean        @default(true)
  thirdPartyFundraiser String?
  controls             String?
  complaintsReceived   Boolean        @default(false)
  reviewOutcome        String?
  status               RegisterStatus @default(OPEN)
  boardMinuteReference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
}

model AnnualReportReadiness {
  id                          String                   @id @default(cuid())
  organisationId              String
  organisation                Organisation             @relation(fields: [organisationId], references: [id])
  reportingYear               Int
  activitiesNarrative         String?
  publicBenefitStatement      String?
  beneficiariesSummary        String?
  financialStatementsApproved Boolean                  @default(false)
  annualReportUploaded        Boolean                  @default(false)
  trusteeDetailsReviewed      Boolean                  @default(false)
  fundraisingReviewed         Boolean                  @default(false)
  complaintsReviewed          Boolean                  @default(false)
  boardApprovalDate           DateTime?
  filingStatus                AnnualReportFilingStatus @default(NOT_STARTED)
  filedDate                   DateTime?
  notes                       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organisationId, reportingYear])
  @@index([organisationId, reportingYear])
}

model FinancialControlReview {
  id                          String       @id @default(cuid())
  organisationId              String
  organisation                Organisation @relation(fields: [organisationId], references: [id])
  reportingYear               Int
  bankReconciliationsReviewed Boolean      @default(false)
  dualAuthorisation           Boolean      @default(false)
  budgetApproved              Boolean      @default(false)
  managementAccountsReviewed  Boolean      @default(false)
  reservesReviewed            Boolean      @default(false)
  restrictedFundsReviewed     Boolean      @default(false)
  assetsInsuranceReviewed     Boolean      @default(false)
  payrollControlsReviewed     Boolean      @default(false)
  fundraisingControlsReviewed Boolean      @default(false)
  reviewedBy                  String?
  reviewDate                  DateTime?
  minuteReference             String?
  actions                     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organisationId, reportingYear])
  @@index([organisationId, reportingYear])
}

model Deadline {
  id                    String                      @id @default(cuid())
  organisationId        String
  organisation          Organisation                @relation(fields: [organisationId], references: [id])
  title                 String
  description           String?
  dueDate               DateTime                    @db.Date
  scheduleVersion       Int                         @default(1)
  isAutoGenerated       Boolean                     @default(false)
  generatedKind         GeneratedDeadlineKind?
  generatedKey          String?
  generationVersion     Int?
  generationRuleVersion Int?
  generationFingerprint String?                     @db.Char(64)
  generationSource      Json?
  generationInputs      Json?
  profileRuleKey        String?
  isComplete            Boolean                     @default(false)
  completedDate         DateTime?
  completionDateKnown   Boolean                     @default(true)
  reminderDays          Int[]                       @default([30, 14, 7])
  supersededAt          DateTime?
  supersededById        String?
  supersessionReason    DeadlineSupersessionReason?
  supersededBy          Deadline?                   @relation("DeadlineSupersession", fields: [supersededById, organisationId], references: [id, organisationId], onDelete: Restrict, onUpdate: Cascade)
  supersedes            Deadline?                   @relation("DeadlineSupersession")
  archivedAt            DateTime?
  reminderLogs          DeadlineReminderLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([id, organisationId])
  @@unique([supersededById, organisationId])
  @@unique([organisationId, generatedKey, generationVersion])
  @@index([organisationId, supersededAt, archivedAt, dueDate])
  @@index([organisationId, isComplete, dueDate])
  @@index([dueDate, id])
}

model TeamInvite {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  email          String
  role           UserRole     @default(MEMBER)
  token          String       @unique
  invitedById    String?
  invitedBy      User?        @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedAt     DateTime?
  revokedAt      DateTime?
  expiresAt      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
  @@index([email])
}

model DeadlineReminderLog {
  id                       String                                 @id @default(cuid())
  organisationId           String
  organisation             Organisation                           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  deadlineId               String
  deadline                 Deadline                               @relation(fields: [deadlineId, organisationId], references: [id, organisationId], onDelete: Cascade, onUpdate: Cascade)
  deadlineScheduleVersion  Int
  deadlineTitle            String
  deadlineDueDate          DateTime                               @db.Date
  deadlineSnapshotKnown    Boolean                                @default(true)
  deliveryTimingKnown      Boolean                                @default(true)
  legacyDeliveryStatus     String?
  legacyRecordedAt         DateTime?
  userId                   String?
  user                     User?                                  @relation(fields: [userId, organisationId], references: [id, organisationId], onDelete: Restrict, onUpdate: Cascade)
  email                    String
  reminderDays             Int
  status                   DeadlineReminderStatus
  reservationToken         String                                 @unique
  providerIdempotencyKey   String?                                @unique
  providerRequestStartedAt DateTime?
  providerMessageId        String?                                @unique
  reconciliationOutcome    DeadlineReminderReconciliationOutcome?
  reconciledAt             DateTime?
  reconciledBy             String?
  reconciliationReference  String?
  error                    String?
  reservedAt               DateTime                               @default(now())
  attemptedAt              DateTime?
  sentAt                   DateTime?

  @@index([organisationId])
  @@index([organisationId, reservedAt, id])
  @@index([userId])
  @@index([deadlineId, status])
  @@index([status, providerRequestStartedAt])
}

model Subscription {
  id                   String             @id @default(cuid())
  organisationId       String             @unique
  organisation         Organisation       @relation(fields: [organisationId], references: [id])
  stripeSubscriptionId String?            @unique
  stripeStatus         String?
  plan                 SubscriptionPlan
  status               SubscriptionStatus @default(TRIALING)
  billingInterval      String?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BillingCheckoutAttempt {
  id                                   String                       @id
  organisationId                       String                       @unique
  organisation                         Organisation                 @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  requestedPlan                        SubscriptionPlan
  interval                             String
  status                               BillingCheckoutAttemptStatus @default(PENDING)
  stripeCheckoutSessionId              String?                      @unique
  checkoutUrl                          String?
  expectedPreviousStripeSubscriptionId String?
  expiresAt                            DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([processedAt])
}
