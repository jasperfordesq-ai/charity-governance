generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganisationComplexity {
  SIMPLE
  COMPLEX
}

enum LegalForm {
  CLG
  TRUST
  UNINCORPORATED_ASSOCIATION
  OTHER
}

enum CharitablePurpose {
  POVERTY_RELIEF
  EDUCATION
  RELIGION
  COMMUNITY_BENEFIT
}

enum ComplianceStatus {
  COMPLIANT
  WORKING_TOWARDS
  NOT_STARTED
  NOT_APPLICABLE
  EXPLAIN
}

enum ComplianceSignoffStatus {
  DRAFT
  BOARD_REVIEW
  APPROVED
}

enum SubscriptionPlan {
  ESSENTIALS
  COMPLETE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum BillingCheckoutAttemptStatus {
  PENDING
  SESSION_CREATED
  COMPLETED
}

enum DocumentCategory {
  CONSTITUTION
  POLICY
  BOARD_MINUTES
  FINANCIAL_STATEMENT
  INSURANCE
  ANNUAL_REPORT
  RISK_REGISTER
  CODE_OF_CONDUCT
  STRATEGIC_PLAN
  OTHER
}

enum RegisterStatus {
  OPEN
  MONITORING
  CLOSED
}

enum ConflictStatus {
  DECLARED
  MANAGED
  CLOSED
}

enum RiskCategory {
  GOVERNANCE
  FINANCIAL
  OPERATIONAL
  LEGAL
  SAFEGUARDING
  REPUTATIONAL
  FUNDRAISING
  DATA_PROTECTION
  OTHER
}

enum AnnualReportFilingStatus {
  NOT_STARTED
  IN_PROGRESS
  BOARD_APPROVED
  FILED
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum DeadlineReminderStatus {
  SENT
  SKIPPED
  FAILED
}

model Organisation {
  id                           String                 @id @default(cuid())
  name                         String
  rcnNumber                    String?
  croNumber                    String?
  legalForm                    LegalForm              @default(CLG)
  complexity                   OrganisationComplexity @default(SIMPLE)
  charitablePurpose            CharitablePurpose[]
  financialYearEnd             DateTime?
  registeredAddress            String?
  contactEmail                 String?
  contactPhone                 String?
  website                      String?
  dateRegistered               DateTime?
  lastAgmDate                  DateTime?
  conditionalObligationProfile Json?

  stripeCustomerId String? @unique

  users                   User[]
  boardMembers            BoardMember[]
  complianceRecords       ComplianceRecord[]
  complianceSignoffs      ComplianceSignoff[]
  documents               Document[]
  deadlines               Deadline[]
  conflictRecords         ConflictRecord[]
  riskRecords             RiskRecord[]
  complaintRecords        ComplaintRecord[]
  fundraisingRecords      FundraisingRecord[]
  annualReportReadiness   AnnualReportReadiness[]
  financialControlReviews FinancialControlReview[]
  teamInvites             TeamInvite[]
  deadlineReminderLogs    DeadlineReminderLog[]
  subscription            Subscription?
  billingCheckoutAttempt  BillingCheckoutAttempt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  passwordHash   String
  role           UserRole     @default(MEMBER)
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  emailVerified  Boolean      @default(false)

  resetToken        String?   @unique
  resetTokenExpiry  DateTime?
  verifyToken       String?   @unique
  verifyTokenExpiry DateTime?

  complianceUpdates ComplianceRecord[]    @relation("UpdatedBy")
  signoffUpdates    ComplianceSignoff[]   @relation("SignoffUpdatedBy")
  documentUploads   Document[]            @relation("UploadedBy")
  sentInvites       TeamInvite[]          @relation("InvitedBy")
  reminderLogs      DeadlineReminderLog[]
  authSessions      AuthSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @unique
  expiresAt        DateTime
  revokedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model GovernancePrinciple {
  id          String @id @default(cuid())
  number      Int    @unique
  title       String
  description String
  sortOrder   Int

  standards GovernanceStandard[]
}

model GovernanceStandard {
  id           String              @id @default(cuid())
  principleId  String
  principle    GovernancePrinciple @relation(fields: [principleId], references: [id])
  code         String              @unique
  title        String
  isCore       Boolean
  isAdditional Boolean
  sortOrder    Int

  complianceRecords ComplianceRecord[]
  documentLinks     DocumentStandardLink[]

  @@index([principleId])
}

model ComplianceRecord {
  id             String             @id @default(cuid())
  organisationId String
  organisation   Organisation       @relation(fields: [organisationId], references: [id])
  standardId     String
  standard       GovernanceStandard @relation(fields: [standardId], references: [id])
  reportingYear  Int

  status          ComplianceStatus @default(NOT_STARTED)
  actionTaken     String?
  evidence        String?
  notes           String?
  explanationIfNA String?

  updatedById String?
  updatedBy   User?   @relation("UpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organisationId, standardId, reportingYear])
  @@index([organisationId, reportingYear])
}

model ComplianceSignoff {
  id               String                  @id @default(cuid())
  organisationId   String
  organisation     Organisation            @relation(fields: [organisationId], references: [id])
  reportingYear    Int
  status           ComplianceSignoffStatus @default(DRAFT)
  boardMeetingDate DateTime?
  minuteReference  String?
  approvedByName   String?
  approvedByRole   String?
  approvalNotes    String?
  approvedAt       DateTime?

  updatedById String?
  updatedBy   User?   @relation("SignoffUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organisationId, reportingYear])
  @@index([organisationId, reportingYear])
}

model BoardMember {
  id                 String           @id @default(cuid())
  organisationId     String
  organisation       Organisation     @relation(fields: [organisationId], references: [id])
  name               String
  role               String
  email              String?
  appointedDate      DateTime
  termEndDate        DateTime?
  isActive           Boolean          @default(true)
  conductSigned      Boolean          @default(false)
  conductSignedDate  DateTime?
  inductionCompleted Boolean          @default(false)
  inductionDate      DateTime?
  conflictRecords    ConflictRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
}

model Document {
  id                   String           @id @default(cuid())
  organisationId       String
  organisation         Organisation     @relation(fields: [organisationId], references: [id])
  name                 String
  description          String?
  category             DocumentCategory
  fileUrl              String
  fileSize             Int
  mimeType             String
  version              Int              @default(1)
  owner                String?
  approvedDate         DateTime?
  nextReviewDate       DateTime?
  boardMinuteReference String?

  uploadedById String?
  uploadedBy   User?   @relation("UploadedBy", fields: [uploadedById], references: [id])

  standardLinks DocumentStandardLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
}

model DocumentStandardLink {
  id         String             @id @default(cuid())
  documentId String
  document   Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  standardId String
  standard   GovernanceStandard @relation(fields: [standardId], references: [id])

  @@unique([documentId, standardId])
}

model DocumentStorageDeletion {
  id             String    @id @default(cuid())
  organisationId String
  storagePath    String
  attempts       Int       @default(0)
  lastError      String?
  claimedAt      DateTime?
  processedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organisationId])
  @@index([processedAt, createdAt])
  @@index([processedAt, claimedAt, createdAt])
}

model ConflictRecord {
  id              String         @id @default(cuid())
  organisationId  String
  organisation    Organisation   @relation(fields: [organisationId], references: [id])
  boardMemberId   String?
  boardMember     BoardMember?   @relation(fields: [boardMemberId], references: [id], onDelete: SetNull)
  trusteeName     String
  matter          String
  nature          String
  dateDeclared    DateTime
  meetingDate     DateTime?
  actionTaken     String
  decision        String?
  status          ConflictStatus @default(DECLARED)
  minuteReference String?
  nextReviewDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
  @@index([boardMemberId])
}

model RiskRecord {
  id                   String         @id @default(cuid())
  organisationId       String
  organisation         Organisation   @relation(fields: [organisationId], references: [id])
  title                String
  category             RiskCategory
  description          String
  likelihood           Int
  impact               Int
  mitigation           String
  owner                String?
  reviewDate           DateTime?
  status               RegisterStatus @default(OPEN)
  boardMinuteReference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
}

model ComplaintRecord {
  id                   String         @id @default(cuid())
  organisationId       String
  organisation         Organisation   @relation(fields: [organisationId], references: [id])
  receivedDate         DateTime
  source               String?
  summary              String
  actionTaken          String?
  outcome              String?
  status               RegisterStatus @default(OPEN)
  reviewedByBoard      Boolean        @default(false)
  boardMinuteReference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
}

model FundraisingRecord {
  id                   String         @id @default(cuid())
  organisationId       String
  organisation         Organisation   @relation(fields: [organisationId], references: [id])
  name                 String
  activityType         String
  startDate            DateTime?
  endDate              DateTime?
  publicFacing         Boolean        @default(true)
  thirdPartyFundraiser String?
  controls             String?
  complaintsReceived   Boolean        @default(false)
  reviewOutcome        String?
  status               RegisterStatus @default(OPEN)
  boardMinuteReference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
}

model AnnualReportReadiness {
  id                          String                   @id @default(cuid())
  organisationId              String
  organisation                Organisation             @relation(fields: [organisationId], references: [id])
  reportingYear               Int
  activitiesNarrative         String?
  publicBenefitStatement      String?
  beneficiariesSummary        String?
  financialStatementsApproved Boolean                  @default(false)
  annualReportUploaded        Boolean                  @default(false)
  trusteeDetailsReviewed      Boolean                  @default(false)
  fundraisingReviewed         Boolean                  @default(false)
  complaintsReviewed          Boolean                  @default(false)
  boardApprovalDate           DateTime?
  filingStatus                AnnualReportFilingStatus @default(NOT_STARTED)
  filedDate                   DateTime?
  notes                       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organisationId, reportingYear])
  @@index([organisationId, reportingYear])
}

model FinancialControlReview {
  id                          String       @id @default(cuid())
  organisationId              String
  organisation                Organisation @relation(fields: [organisationId], references: [id])
  reportingYear               Int
  bankReconciliationsReviewed Boolean      @default(false)
  dualAuthorisation           Boolean      @default(false)
  budgetApproved              Boolean      @default(false)
  managementAccountsReviewed  Boolean      @default(false)
  reservesReviewed            Boolean      @default(false)
  restrictedFundsReviewed     Boolean      @default(false)
  assetsInsuranceReviewed     Boolean      @default(false)
  payrollControlsReviewed     Boolean      @default(false)
  fundraisingControlsReviewed Boolean      @default(false)
  reviewedBy                  String?
  reviewDate                  DateTime?
  minuteReference             String?
  actions                     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organisationId, reportingYear])
  @@index([organisationId, reportingYear])
}

model Deadline {
  id              String                @id @default(cuid())
  organisationId  String
  organisation    Organisation          @relation(fields: [organisationId], references: [id])
  title           String
  description     String?
  dueDate         DateTime
  isAutoGenerated Boolean               @default(false)
  isComplete      Boolean               @default(false)
  completedDate   DateTime?
  reminderDays    Int[]                 @default([30, 14, 7])
  reminderLogs    DeadlineReminderLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
}

model TeamInvite {
  id             String       @id @default(cuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  email          String
  role           UserRole     @default(MEMBER)
  token          String       @unique
  invitedById    String?
  invitedBy      User?        @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedAt     DateTime?
  revokedAt      DateTime?
  expiresAt      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organisationId])
  @@index([email])
}

model DeadlineReminderLog {
  id             String                 @id @default(cuid())
  organisationId String
  organisation   Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  deadlineId     String
  deadline       Deadline               @relation(fields: [deadlineId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  email          String
  reminderDays   Int
  status         DeadlineReminderStatus
  error          String?
  sentAt         DateTime               @default(now())

  @@unique([deadlineId, email, reminderDays])
  @@index([organisationId])
  @@index([userId])
}

model Subscription {
  id                   String             @id @default(cuid())
  organisationId       String             @unique
  organisation         Organisation       @relation(fields: [organisationId], references: [id])
  stripeSubscriptionId String?            @unique
  stripeStatus         String?
  plan                 SubscriptionPlan
  status               SubscriptionStatus @default(TRIALING)
  billingInterval      String?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BillingCheckoutAttempt {
  id                                   String                       @id
  organisationId                       String                       @unique
  organisation                         Organisation                 @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  requestedPlan                        SubscriptionPlan
  interval                             String
  status                               BillingCheckoutAttemptStatus @default(PENDING)
  stripeCheckoutSessionId              String?                      @unique
  checkoutUrl                          String?
  expectedPreviousStripeSubscriptionId String?
  expiresAt                            DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([processedAt])
}
